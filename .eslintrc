{
  "root": true,
  "env": {
    "browser": true,
    "jquery": true,
    "es6": false
  },
  "extends": "eslint-config-airbnb/legacy",
  "globals": {
    "revapi92": true,
    "revslider_showDoubleJqueryError": true,
    "jRespond": true
  },
  "rules": {
    "strict": [2, "function"],
    "no-unused-vars": [1, {"vars": "local", "args": "none"}],
    "radix": 0,
    "max-len": [1, 120, 2, { "ignoreComments": true }],
    "func-names": 0,
    "comma-dangle": [ 2, "never" ],
    "padded-blocks": 0,

    // disable ES2015 sepcific rules
    "arrow-parens": 0,
    "arrow-spacing": 0,
    "constructor-super": 0,
    "generator-star-spacing": 0,
    "no-class-assign": 0,
    "no-const-assign": 0,
    "no-dupe-class-members": 0,
    "no-this-before-super": 0,
    "no-var": 0,
    "object-shorthand": 0,
    "prefer-arrow-callback": 0,
    "prefer-const": 0,
    "prefer-reflect": 0,
    "prefer-spread": 0,
    "prefer-template": 0,
    "require-yield": 0
  }
}
