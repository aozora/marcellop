{
  "name": "marcellop",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run sass:build",
    "build:remix": "remix build",
    "dev": "concurrently \"npm run sass\" \"remix dev\"",
    "format": "prettier --write",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint",
    "sass": "sass --load-path=node_modules --watch app/:app/",
    "sass:build": "sass --load-path=node_modules app/:app/",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "start": "remix-serve build",
    "start:mocks": "binode --require mocks -- @remix-run/serve:remix-serve build",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "prettier": {},
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@remix-run/node": "^1.12.0",
    "@remix-run/react": "^1.12.0",
    "@remix-run/serve": "^1.15.0",
    "@remix-run/server-runtime": "^1.12.0",
    "@remix-run/vercel": "^1.15.0",
    "@vercel/kv": "^0.2.0",
    "@vercel/node": "^2.10.3",
    "@vercel/remix": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.0.1",
    "isbot": "^3.6.5",
    "react": "^18.2.0",
    "react-datocms": "^4.0.9",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "sass": "^1.58.3",
    "tiny-invariant": "^1.3.1",
    "tiny-json-http": "^7.4.2"
  },
  "devDependencies": {
    "@remix-run/dev": "^1.13.0",
    "@remix-run/eslint-config": "^1.13.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/eslint": "^8.4.10",
    "@types/node": "^20.1.4",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@types/react-helmet": "^6.1.6",
    "@types/tiny-json-http": "^7.3.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.13",
    "binode": "^1.0.5",
    "c8": "^7.12.0",
    "cookie": "^0.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-cypress": "^2.12.1",
    "happy-dom": "^9.18.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "prettier": "^2.8.3",
    "start-server-and-test": "^2.0.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^5.0.4",
    "vite": "^4.0.4",
    "vite-tsconfig-paths": "^4.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
